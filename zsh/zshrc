# Path to your oh-my-zsh configuration.
ZSH=$HOME/.oh-my-zsh

# Set name of the theme to load.
ZSH_THEME="sorin"

# Disable command autocorrection
DISABLE_CORRECTION="true"

# Plugins (custom/*.zsh files are sourced automatically by oh-my-zsh)
plugins=(macos)

set -k

source $ZSH/oh-my-zsh.sh

source "$HOME/.zsh/exports.zsh"

# conda is lazy-loaded in custom/conda.zsh — the eager `conda init` block
# that used to live here cost ~1.6s of Python startup on every shell.

export PATH="$HOME/.local/bin:$PATH"

# fzf shell integration (ctrl-r history, ctrl-t file finder)
eval "$(fzf --zsh)"

# zoxide smart cd (use: z <directory>)
eval "$(zoxide init zsh)"
